{
  "expo": {
    "name": "Task To Do",
    "slug": "tasktodo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#e3f2fd"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#e3f2fd"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-status-bar",
      "expo-secure-store"
    ]
  }
}
